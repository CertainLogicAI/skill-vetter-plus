{
  "name": "skill-vetter-plus",
  "version": "1.0.1",
  "description": "Security scanner for AI agent skills. Checks manifests, scripts, and prompts for vulnerabilities before installation or publication.",
  "author": "CertainLogic",
  "license": "MIT",
  "category": "security",
  "tags": ["security", "scanner", "vulnerability", "audit", "static-analysis", "prompt-injection"],
  "requirements": {
    "python": ">=3.10",
    "optional": ["semgrep"]
  },
  "entry": {
    "cli": "scripts/vetter.py",
    "library": "vetter.SkillScanner"
  },
  "commands": [
    {
      "name": "scan",
      "description": "Scan a skill directory for security issues",
      "args": [
        {
          "name": "path",
          "type": "string",
          "required": true,
          "description": "Path to the skill directory to scan"
        },
        {
          "name": "verbose",
          "type": "boolean",
          "default": false,
          "description": "Show detailed output with remediation hints"
        },
        {
          "name": "json",
          "type": "boolean",
          "default": false,
          "description": "Output findings as JSON"
        },
        {
          "name": "deep",
          "type": "boolean",
          "default": false,
          "description": "Use extended semgrep rules (requires semgrep)"
        }
      ]
    },
    {
      "name": "scan-batch",
      "description": "Scan multiple skill directories",
      "args": [
        {
          "name": "paths",
          "type": "array",
          "required": true,
          "description": "List of skill directory paths"
        }
      ]
    }
  ],
  "repository": "https://github.com/certainlogic/skill-vetter-plus",
  "homepage": "https://github.com/certainlogic/skill-vetter-plus#readme",
  "bugs": "https://github.com/certainlogic/skill-vetter-plus/issues"
}
